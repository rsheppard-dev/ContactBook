@model IEnumerable<ContactBook.Models.Category>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row mt-5">
    <div class="col-12 text-end mb-2">
        <a class="btn btn-primary rounded-pill" asp-action="Create">Create New</a>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <table class="table table-striped table-hover">
            <thead>
            <tr>
                <th colspan="2">
                    @Html.DisplayNameFor(model => model.Name)
                </th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td class="d-flex justify-content-end">
                        <a class="me-3 editIcons" asp-action="Edit" asp-route-id="@item.Id" asp-controller="Categories"><i class="bi bi-pencil-fill"></i></a>
                        <a class="me-3 editIcons" asp-action="EmailCategory" asp-route-id="@item.Id" asp-controller="Categories"><i class="bi bi-envelope-fill"></i></a>
                        <a class="editIcons text-danger" asp-action="Delete" asp-route-id="@item.Id" asp-controller="Categories"><i class="bi bi-trash-fill "></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
